{
    "name": "ksfraser/ksf-fa-common",
    "description": "Shared FrontAccounting platform utilities, contracts, and extension points for the KSF ecosystem",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=7.4",
        "ksfraser/exceptions": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "KsfCommon\\": "src/"
        },
        "files": [
            "src/logging_functions.php"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "ksf": {
            "module-type": "platform-common"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
