{
    "name": "ksfraser/ksf-fa-common",
    "description": "Shared FrontAccounting platform utilities, contracts, and extension points for the KSF ecosystem",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=7.3",
        "ksfraser/exceptions": "^1.3",
        "ksfraser/ksf_gpg": "@dev"
    },
    "autoload": {
        "psr-4": {
            "ksfraser\\FrontAccounting\\Common\\": "src/",
            "KsfCommon\\": "src/"
        },
        "files": [
            "src/logging_functions.php",
            "src/compat.php"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [
        {"type": "path", "url": "../ksf_GPG"}
    ],
    "extra": {
        "ksf": {
            "module-type": "platform-common"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload-dev": {
        "psr-4": {
            "ksfraser\\FrontAccounting\\Common\\Tests\\": "tests/",
            "KsfCommon\\Test\\": "tests/",
            "KsfCommon\\Tests\\": "tests/"
        }
    }
}
